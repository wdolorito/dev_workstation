+++ .mkshrc	2026-05-21 12:52:09.215030423 -0600
@@ -18,7 +18,7 @@
 [[ -s /etc/mkshrc ]] && \. /etc/mkshrc
 
 # work around #813164
-\\builtin alias ls='ls -N'
+\\builtin alias ls='ls -N --color=auto'
 
 # prepend $debian_chroot support to PS1
 p=$'\001'
@@ -50,4 +50,28 @@
 #\\builtin export LANG=C.UTF-8 LC_CTYPE=C.UTF-8
 #\\builtin export LC_ALL=C.UTF-8
 
-\: make sure this is the last line, to ensure a good return code
+# ssh-agent
+if [ -z "$SSH_AUTH_SOCK" ] && ! [ "$TERM_PROGRAM" = "vscode" ]
+then
+	export SSH_AUTH_SOCK="$HOME"/.ssh/ssh-agent.socket
+	export SSH_ASKPASS_REQUIRE="never"
+fi
+"$HOME"/.ssh/add_ssh_keys
+
+# pipewire
+"$HOME"/local/bin/start_audio
+
+if [ "$TERM" = "linux" ]
+then
+        "$HOME"/local/bin/start_tmux
+fi
+
+FORTUNE="$(which fortune 2>&1)" >/dev/null
+if [ -x "$FORTUNE" ]
+then
+	$FORTUNE
+fi
+
+export HISTFILE="$HOME"/.mksh_history
+
+trap "$(which mksh) $HOME/.mksh_logout" 0
