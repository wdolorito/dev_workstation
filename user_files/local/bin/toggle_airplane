#!/bin/sh

#
# ~/local/bin/toggle_airplane
#

RFKILL="$(which /sbin/rfkill 2>/dev/null)"
DHCLIENT="$(which dhclient 2>/dev/null)"
STATUS="$($RFKILL 2>/dev/null | grep wlan | awk '{print $4}')"

if [ -z "$RFKILL" ]
then
	echo "rfkill command not available."
	exit 127
fi

if [ -z "$DHCLIENT" ]
then
	echo "dhclient command not available."
	exit 127
fi

disable_wireless() {
	$RFKILL block all >/dev/null 2>&1
	$DHCLIENT -r >/dev/null 2>&1
}

enable_wireless() {
	$RFKILL unblock all >/dev/null 2>&1
	$DHCLIENT >/dev/null 2>&1
}

toggle() {
	if [ "$STATUS" = "unblocked" ]
	then
		disable_wireless
	else
		enable_wireless
	fi
}

case "$1" in
	"kill" )
		disable_wireless
		;;
	"enable" )
		enable_wireless
		;;
	* )
		toggle
		;;
esac
