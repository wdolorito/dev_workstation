#!/bin/sh

#
# ~/local/bin/bright
#

CMD="$(which brightnessctl 2>/dev/null)"
DEV=""
DISPVAL=0
DOOB=1
OUTPUTFILE="$HOME/.bright"

if [ -z "$CMD" ]
then
	echo "brightnessctl not available."
	exit 127
fi

DEV="$($CMD | tr -d \' | grep backlight | awk '{print $2}')"

if [ -z "$DEV" ]
then
	echo "this system does not have a display backlight."
	exit 1
fi

COMP="$(echo "$1" | tr '[:upper:]' '[:lower:]')"
case "$COMP" in
	"file" )
		echo "$OUTPUTFILE"
		exit
		;;
	"up" )
		$CMD -qd "$DEV"  set +5%
		;;
	"down" )
		$CMD -qd "$DEV" set 5%-
		;;
	"off" )
		$CMD -qsd "$DEV"
		$CMD -qd "$DEV" set 0%
		;;
	"on" )
		$CMD -qrd "$DEV"
		;;
	[0-9]* )
		$CMD -qd "$DEV" set "$COMP"%
		;;
	* )
		;;
esac

if [ -n "$2" ]
then
	if [ "$2" = "false" ]
	then
		DOOB=0
	fi
fi

DISPVAL="$($CMD -d "$DEV" | sed -n 2p | awk '{print $4}' | tr -d '()')"

if env | grep -q DISPLAY
then
	echo "$DISPVAL" > "$OUTPUTFILE"
	if [ "$DOOB" -eq 1 ]
	then
		echo "$DISPVAL" | tr -d "%" | xargs do_ob
	fi
else
	echo "$DISPVAL"
fi
