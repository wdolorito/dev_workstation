#!/bin/sh

#
# ~/local/bin/start_tmux
#

FBTERM="$(which fbterm 2>/dev/null)"
TMUXCMD="$(which tmux 2>/dev/null)"
SESSION="$XDG_SEAT-$XDG_SESSION_ID"

if [ -z "$TMUXCMD" ]
then
	echo "tmux command not available."
	exit 127
fi

launch() {
		if [ -z "$1" ]
		then
			$TMUXCMD "$2" -t "$SESSION"
		else
			if [ -n "$FBTERM" ]
			then
				$FBTERM -- "$TMUXCMD" "$2" -t "$SESSION"
			else
				echo "fbterm command not available."
				exit 127
			fi
		fi
}

run_tmux() {
	if ! tmux has-session -t="$SESSION" > /dev/null 2>&1
	then
		TMUX="" $TMUXCMD new-session -d -s "$SESSION"
	fi

	if [ -z "$TMUX" ]
	then
		launch "$1" "attach-session"
	else
		launch "$1" "switch-client"
	fi
}

if [ -t 0 ]
then
	if [ -n "$1" ]
	then
		SESSION="$1"
	fi

	if [ "$XDG_SESSION_TYPE" = "tty" ] || [ -z "$XDG_SESSION_TYPE" ]
	then
		run_tmux "fbterm"
	else
		run_tmux
	fi
fi
