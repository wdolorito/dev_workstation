#!/bin/sh

#
# ~/local/bin/floorp
#

FLATPAK="$(which flatpak 2>/dev/null)"
INSTALLED=""
PKG="one.ablaze.floorp"
TOTMP="$(which browser_profile_to_tmpfs 2>/dev/null)"
PDATA="$HOME/.floorp"
PTEMPFILE="$HOME/.flrun"

launch() {
	case "$XDG_SESSION_TYPE" in
		"wayland" | "x11")
			$FLATPAK run "$PKG" "$@"
			;;
		* )
			echo "Not in a graphical session."
			exit 1
			;;
	esac
}

check_temp() {
	case "$1" in
		"clean" )
			$TOTMP clean "$PDATA" "$PTEMPFILE"
			;;
		"copy" )
			$TOTMP  copy "$PDATA" "$PTEMPFILE"
			;;
		"recover" )
			$TOTMP  recover "$PDATA" "$PTEMPFILE"
			;;
		"sync" )
			$TOTMP  sync "$PDATA" "$PTEMPFILE"
			;;
		* )
			launch "$@"
			;;
	esac
}

if [ -z "$FLATPAK" ]
then
	echo "flatpak command not available."
	exit 127
else
	INSTALLED="$($FLATPAK list | grep $PKG)"

	if [ -n "$INSTALLED" ]
	then
		if [ -n "$TOTMP" ]
		then
			check_temp "$@"
		else
			launch "$@"
		fi
	else
		echo "floorp flatpak not installed."
		exit 127
	fi
fi
