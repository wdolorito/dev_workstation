#!/bin/sh

APT="apt-get"
SUDO="$(which sudo 2>/dev/null)"

do_system_update() {
	$SUDO "$APT" update
	$SUDO "$APT" -y dist-upgrade
	$SUDO "$APT" -y autoremove --purge
	$SUDO "$APT" autoclean
	$SUDO "$APT" clean
}

if [ -n "$SUDO" ]
then
	do_system_update
	flatpak_update
else
	echo "sudo command not available."
	exit 127
fi
