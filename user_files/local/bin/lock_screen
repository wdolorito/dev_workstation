#!/bin/sh

#
# ~/local/bin/lock_screen
#

PHYSLOCK="$(which physlock 2>/dev/null)"
LOCK="$(which lock_msg 2>/dev/null)"
MSG="$(printf "%s locked this workstation named %s" "$(whoami)" "$(hostname)")"

if [ -n "$LOCK" ]
then
	MSG="$($LOCK)"
fi

if [ -n "$PHYSLOCK" ]
then
	$PHYSLOCK -dmsp "$MSG"
else
	echo "physlock command not available."
	exit 127
fi
