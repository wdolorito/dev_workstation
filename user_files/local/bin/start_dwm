#!/bin/sh

#
# ~/local/bin/start_dwm
#

DWMLOG="$HOME/.dwm.log"
FEHBG="$HOME/.fehbg"
BRIGHT="$(bright file 2>/dev/null)"
LOCKER="$HOME/.screenlocker"
OBSOCK="$(make_ob_sock 2>/dev/null)"
_XDG_SESSION_TYPE="$XDG_SESSION_TYPE"
XDG_SESSION_TYPE="x11"

if [ -f "$DWMLOG" ]
then
	rm -f "$DWMLOG"
fi

if ! [ -d "$HOME/.local/.fpbin" ]
then
	gen_fpbins 2>/dev/null
fi

export OBSOCK
ln -s "$HOME/.xinitrc-suckless" "$HOME/.xinitrc"
startx 2>/dev/null
XDG_SESSION_TYPE="$_XDG_SESSION_TYPE"

if [ -f "$FEHBG" ]
then
	rm -f "$FEHBG"
fi

if ! [ -s "$DWMLOG" ]
then
	rm -f "$DWMLOG"
else
	echo "check ${DWMLOG}"
fi

if [ -f "$BRIGHT" ]
then
	rm -f "$BRIGHT"
fi

if [ -f "$LOCKER" ]
then
	rm -f "$LOCKER"
fi

if [ -p "$OBSOCK" ]
then
	make_ob_sock destroy 2>/dev/null
	do_ob clean 2>/dev/null
	unset OBSOCK
fi

rm -f "$HOME/.xinitrc"
